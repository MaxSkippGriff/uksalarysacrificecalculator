<!-- STICKY BAR -->
<div class="sticky-result" id="stickyResult">
  <div class="sticky-result-inner">
    <div>
      <div class="sr-label">Total employer cost</div>
      <div class="sr-value" id="stickyValue">£44,750 / year</div>
    </div>
    <div style="text-align:right">
      <div class="sr-detail" id="stickyDetail">£3,729 / month</div>
      <div class="sr-detail" id="stickyAbove">27.9% above salary</div>
    </div>
  </div>
</div>

<script>
// ── 2025/26 EMPLOYER NI THRESHOLDS ──
const NI_SECONDARY_THRESHOLD = 5000;  // annual
const NI_RATE = 0.15;  // 15%

function parseCurrency(str) {
  return parseInt(String(str).replace(/[^0-9]/g, ''), 10) || 0;
}

function fmt(n) {
  return '£' + Math.round(n).toLocaleString('en-GB');
}

function fmtDec(n) {
  return '£' + n.toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function calcEmployerNI(salary, allowance) {
  const niable = Math.max(0, salary - NI_SECONDARY_THRESHOLD);
  const grossNI = niable * NI_RATE;
  const niAfterAllowance = Math.max(0, grossNI - allowance);
  return { grossNI, niAfterAllowance, allowanceSaving: grossNI - niAfterAllowance, niable };
}

function calcPension(salary, rate) {
  // Auto-enrolment qualifying earnings: £6,240 to £50,270 for 2025/26
  const lowerQE = 6240;
  const upperQE = 50270;
  const qualifying = Math.max(0, Math.min(salary, upperQE) - lowerQE);
  return qualifying * (rate / 100);
}

function calculate() {
  const salary = parseCurrency(document.getElementById('salary').value);
  const pensionRate = parseFloat(document.getElementById('pension').value);
  const overheads = parseCurrency(document.getElementById('overheads').value);
  const allowance = parseFloat(document.getElementById('empAllowance').value);

  if (salary < 1) return;

  const ni = calcEmployerNI(salary, allowance);
  const pension = calcPension(salary, pensionRate);
  const totalCost = salary + ni.niAfterAllowance + pension + overheads;
  const aboveSalary = totalCost - salary;
  const abovePercent = ((aboveSalary / salary) * 100).toFixed(1);

  // Update results
  document.getElementById('totalCostDisplay').textContent = fmt(totalCost);
  document.getElementById('rTotalAnnual').textContent = fmt(totalCost);
  document.getElementById('rTotalMonthly').textContent = fmt(totalCost / 12);
  document.getElementById('rEmployerNI').textContent = fmt(ni.niAfterAllowance);
  document.getElementById('rNIMonthly').textContent = fmt(ni.niAfterAllowance / 12);
  document.getElementById('rPension').textContent = fmt(pension);
  document.getElementById('rPensionMonthly').textContent = fmt(pension / 12);
  document.getElementById('rOverhead').textContent = fmt(overheads);
  document.getElementById('rOverheadMonthly').textContent = fmt(overheads / 12);
  document.getElementById('rAboveSalary').textContent = fmt(aboveSalary);
  document.getElementById('rAbovePercent').textContent = abovePercent + '%';
  document.getElementById('rAllowance').textContent = fmt(ni.allowanceSaving);

  // Breakdown table
  const bd = document.getElementById('breakdownBody');
  bd.innerHTML = `
    <tr><td>Gross salary</td><td>${fmtDec(salary)}</td></tr>
    <tr><td>Employer NI (15% above £5,000)</td><td>${fmtDec(ni.grossNI)}</td></tr>
    ${ni.allowanceSaving > 0 ? `<tr><td>Employment Allowance offset</td><td>−${fmtDec(ni.allowanceSaving)}</td></tr>` : ''}
    <tr><td>Employer pension (${pensionRate}% on qualifying earnings)</td><td>${fmtDec(pension)}</td></tr>
    <tr><td>Overhead costs</td><td>${fmtDec(overheads)}</td></tr>
    <tr><td>Total employer cost</td><td>${fmtDec(totalCost)}</td></tr>
  `;

  // NI bands
  const nib = document.getElementById('niBandsBody');
  const earningsUpToThreshold = Math.min(salary, NI_SECONDARY_THRESHOLD);
  const earningsAboveThreshold = Math.max(0, salary - NI_SECONDARY_THRESHOLD);
  nib.innerHTML = `
    <tr><td>Up to £${NI_SECONDARY_THRESHOLD.toLocaleString()}</td><td>0%</td><td>${fmtDec(0)}</td></tr>
    <tr><td>Above £${NI_SECONDARY_THRESHOLD.toLocaleString()}</td><td>15%</td><td>${fmtDec(earningsAboveThreshold * NI_RATE)}</td></tr>
    <tr><td>Total employer NI</td><td></td><td>${fmtDec(ni.grossNI)}</td></tr>
  `;

  // Assumptions
  document.getElementById('assumptionsBlock').innerHTML = `
    <strong>Tax year:</strong> 2025/26 · <strong>Employer NI rate:</strong> 15% ·
    <strong>Secondary threshold:</strong> £5,000/year ·
    <strong>Pension:</strong> ${pensionRate}% on qualifying earnings (£6,240–£50,270) ·
    <strong>Employment Allowance:</strong> ${allowance > 0 ? fmt(allowance) : 'Not applied'} ·
    <strong>Overheads:</strong> ${fmt(overheads)}/year ·
    Estimates only — not financial advice.
  `;

  // Sticky bar
  document.getElementById('stickyValue').textContent = fmt(totalCost) + ' / year';
  document.getElementById('stickyDetail').textContent = fmt(totalCost / 12) + ' / month';
  document.getElementById('stickyAbove').textContent = abovePercent + '% above salary';
}

function setSalary(val) {
  document.getElementById('salary').value = val.toLocaleString('en-GB');
  calculate();
}

// Event listeners
['salary', 'pension', 'overheads', 'empAllowance'].forEach(id => {
  document.getElementById(id).addEventListener('input', calculate);
  document.getElementById(id).addEventListener('change', calculate);
});

// Format salary on blur
document.getElementById('salary').addEventListener('blur', function() {
  const v = parseCurrency(this.value);
  if (v > 0) this.value = v.toLocaleString('en-GB');
});
document.getElementById('overheads').addEventListener('blur', function() {
  const v = parseCurrency(this.value);
  if (v > 0) this.value = v.toLocaleString('en-GB');
});

// Sticky bar visibility
const resultsPanel = document.getElementById('resultsPanel');
const stickyResult = document.getElementById('stickyResult');
const observer = new IntersectionObserver(([entry]) => {
  stickyResult.classList.toggle('visible', !entry.isIntersecting);
}, { threshold: 0.1 });
observer.observe(resultsPanel);

// Initial calculation
calculate();
</script>

</body>
</html>
